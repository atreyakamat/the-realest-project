= useState<string | null>(null);\r\n\r\n  async function handleClick() {\r\n    setLoading(true);\r\n    setError(null);\r\n    setSuccess(null);\r\n    try {\r\n      const res = await fetch('/api/workflow/execute', {\r\n        method: 'POST',\r\n        headers: { 'Content-Type': 'application/json' },\r\n        body: JSON.stringify({ leadId, actionId, dryRun: true }),\r\n      });\r\n      const json = await res.json();\r\n      if (!res.ok) throw new Error(json?.error || 'Request failed');\r\n      setSuccess('Action recorded (dry-run)');\r\n    } catch (err: any) {\r\n      setError(err.message ?? String(err));\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }\r\n\r\n  return (\r\n    <div>\r\n      <button\r\n        onClick={handleClick}\r\n        disabled={loading}\r\n        className=\"inline-flex items-center gap-2 rounded-2xl border border-white/10 bg-white/5 px-4 py-2 text-sm\"\r\n      >\r\n        {loading ? 'Recording...' : children ?? 'Take recommended action'}\r\n      </button>\r\n      {success ? <p className=\"mt-2 text-xs text-emerald-300\">{success}</p> : null}\r\n      {error ? <p className=\"mt-2 text-xs text-red-400\">{error}</p> : null}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Projects\\the-realest-project\\src\\lib\\auth.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projects\\the-realest-project\\src\\lib\\data.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projects\\the-realest-project\\src\\lib\\estateflow-types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Projects\\the-realest-project